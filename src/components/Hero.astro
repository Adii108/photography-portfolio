---
interface Props {
  headline?: string;
  sub?: string;
}

const {
  headline = 'The World\nThrough\nWild Eyes',
  sub = 'Mountains, forests, trails — one frame at a time.',
} = Astro.props;
---

<section class="hero" aria-label="Hero">
  <div class="hero__bg" aria-hidden="true">
    <img
      src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1800&auto=format&fit=crop&q=80"
      alt=""
      class="hero__img"
      fetchpriority="high"
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    <p class="hero__eyebrow">Nature · Trek · Photography</p>
    <h1 class="hero__headline display">{headline}</h1>
    <p class="hero__sub">{sub}</p>
    <div class="hero__cta">
      <a href="/gallery" class="btn btn--primary">Explore Gallery</a>
      <a href="/about" class="btn btn--ghost">The Story</a>
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-line"></span>
    <span class="hero__scroll-label">Scroll</span>
  </div>
</section>

<style>
.hero {
  position: relative;
  height: 100dvh;
  min-height: 560px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
}

.hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  animation: heroScale 16s ease-in-out infinite alternate;
}

@keyframes heroScale {
  from { transform: scale(1); }
  to   { transform: scale(1.06); }
}

@media (prefers-reduced-motion: reduce) {
  .hero__img { animation: none; }
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to top, rgba(26,26,24,0.85) 0%, rgba(26,26,24,0.2) 60%, transparent 100%),
    linear-gradient(to right, rgba(26,26,24,0.4) 0%, transparent 60%);
}

.hero__content {
  position: relative;
  z-index: 2;
  padding: 0 2.5rem 5rem;
  max-width: 780px;
}

.hero__eyebrow {
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(245,240,232,0.55);
  margin-bottom: 1.25rem;
}

.hero__headline {
  font-size: clamp(3.5rem, 9vw, 8rem);
  font-weight: 700;
  color: var(--paper);
  white-space: pre-line;
  margin-bottom: 1.5rem;
}

.hero__sub {
  font-size: 1.05rem;
  color: rgba(245,240,232,0.65);
  margin-bottom: 2.5rem;
  max-width: 380px;
}

.hero__cta {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.btn {
  display: inline-block;
  padding: 0.75rem 2rem;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 2px;
  transition: all 0.2s;
}

.btn--primary {
  background: var(--sunset);
  color: var(--paper);
}

.btn--primary:hover {
  background: #d96b3a;
  transform: translateY(-1px);
}

.btn--ghost {
  border: 1px solid rgba(245,240,232,0.35);
  color: var(--paper);
}

.btn--ghost:hover {
  border-color: var(--paper);
  background: rgba(245,240,232,0.06);
}

/* Scroll indicator */
.hero__scroll {
  position: absolute;
  right: 2rem;
  bottom: 3rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  z-index: 2;
}

.hero__scroll-line {
  display: block;
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, transparent, rgba(245,240,232,0.4));
  animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.4; transform: scaleY(1); }
  50%       { opacity: 1;   transform: scaleY(1.2); }
}

@media (prefers-reduced-motion: reduce) {
  .hero__scroll-line { animation: none; }
}

.hero__scroll-label {
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(245,240,232,0.35);
  writing-mode: vertical-rl;
}

@media (max-width: 600px) {
  .hero__content { padding: 0 1.25rem 4rem; }
  .hero__scroll   { display: none; }
}
</style>
