---
import type { PhotoEntry } from '../lib/photos';

interface Props {
  photo: PhotoEntry;
  /** Grid span variant — controls aspect feel inside the collage grid */
  variant?: 'portrait' | 'landscape' | 'square' | 'wide';
}

const { photo, variant = 'portrait' } = Astro.props;
const alt = photo.caption ?? photo.place ?? 'Nature photo';
---

<a
  href={`/story/${photo.slug}`}
  class:list={['photo-card', `photo-card--${variant}`]}
  data-category={photo.category ?? 'other'}
  aria-label={alt}
>
  <img
    src={photo.imageUrl}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="photo-card__img"
  />

  <!-- Hover overlay with metadata -->
  <div class="photo-card__info" aria-hidden="true">
    {photo.category && <span class="photo-card__cat">{photo.category}</span>}
    {photo.place    && <p   class="photo-card__place">{photo.place}</p>}
    {photo.caption  && <p   class="photo-card__caption">{photo.caption}</p>}
  </div>
</a>

<style is:global>
.photo-card {
  display: block;
  position: relative;
  overflow: hidden;
  border-radius: 14px;
  isolation: isolate;
  text-decoration: none;
  width: 100%;
  height: 100%;
  background: rgba(245,240,232,0.04);
  /* subtle border for depth */
  box-shadow:
    0 0 0 1px rgba(245,240,232,0.07),
    0 4px 24px rgba(0,0,0,0.35);
  transition: transform 0.4s var(--ease-out-expo, cubic-bezier(0.16,1,0.3,1)),
              box-shadow 0.4s ease;
}

.photo-card:hover {
  transform: translateY(-4px) scale(1.012);
  box-shadow:
    0 0 0 1px rgba(200,90,42,0.3),
    0 12px 40px rgba(0,0,0,0.5);
}

/* ── Image fills the whole card ── */
.photo-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  will-change: transform;
  transition: transform 0.55s var(--ease-out-expo, cubic-bezier(0.16,1,0.3,1));
}

.photo-card:hover .photo-card__img {
  transform: scale(1.07);
}

/* ── Hover info panel ── */
.photo-card__info {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1rem 1.1rem;
  background: linear-gradient(
    to top,
    rgba(26,26,24,0.88) 0%,
    rgba(26,26,24,0.3) 40%,
    transparent 70%
  );
  opacity: 0;
  transition: opacity 0.3s ease;
}

.photo-card:hover .photo-card__info {
  opacity: 1;
}

.photo-card__cat {
  font-size: 0.58rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--sunset);
  margin-bottom: 0.25rem;
}

.photo-card__place {
  font-size: 0.7rem;
  color: rgba(245,240,232,0.55);
  letter-spacing: 0.04em;
  margin-bottom: 0.2rem;
}

.photo-card__caption {
  font-family: 'Cormorant Garamond', serif;
  font-size: 0.95rem;
  color: var(--paper);
  line-height: 1.3;
}
</style>
