---
import type { PhotoEntry } from '../lib/photos';

interface Props {
  photo: PhotoEntry;
}

const { photo } = Astro.props;
const alt = photo.caption ?? photo.place ?? 'Nature photo';
---

<a
  href={`/story/${photo.slug}`}
  class="photo-card"
  data-category={photo.category ?? 'other'}
  aria-label={alt}
>
  <div class="photo-card__img-wrap">
    <img
      src={photo.imageUrl}
      alt={alt}
      loading="lazy"
      decoding="async"
      class="photo-card__img"
    />
    <div class="photo-card__overlay" aria-hidden="true"></div>
  </div>
  <div class="photo-card__meta">
    {photo.category && (
      <span class="photo-card__category">{photo.category}</span>
    )}
    {photo.place && <p class="photo-card__place">{photo.place}</p>}
    {photo.caption && <p class="photo-card__caption">{photo.caption}</p>}
  </div>
</a>

<style>
.photo-card {
  display: block;
  text-decoration: none;
  position: relative;
  overflow: hidden;
  border-radius: 3px;
  background: rgba(245,240,232,0.04);
  /* Promote to own layer — avoids repaints of sibling cards */
  isolation: isolate;
  transition: transform 0.35s var(--ease-out-expo, cubic-bezier(0.16,1,0.3,1));
}

.photo-card:hover {
  transform: translateY(-5px);
}

.photo-card__img-wrap {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
}

.photo-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  will-change: transform;
  transition: transform 0.55s var(--ease-out-expo, cubic-bezier(0.16,1,0.3,1));
}

.photo-card:hover .photo-card__img {
  transform: scale(1.06);
}

.photo-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(26,26,24,0.85) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.35s ease;
}

.photo-card:hover .photo-card__overlay {
  opacity: 1;
}

.photo-card__meta {
  padding: 0.9rem 1rem;
}

.photo-card__category {
  font-size: 0.6rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--sunset);
  display: block;
  margin-bottom: 0.3rem;
}

.photo-card__place {
  font-size: 0.75rem;
  color: rgba(245,240,232,0.5);
  letter-spacing: 0.05em;
  margin-bottom: 0.25rem;
}

.photo-card__caption {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem;
  color: var(--paper);
  line-height: 1.35;
}
</style>
