---
import type { PhotoEntry, Category } from '../lib/photos';
import PhotoCard from './PhotoCard.astro';
import { CATEGORIES } from '../lib/categories';

interface Props {
  photos: PhotoEntry[];
  initialCategory?: Category | 'all';
}

const { photos, initialCategory = 'all' } = Astro.props;

/**
 * Cycle through a repeating pattern of variants so the collage looks
 * natural and varied without needing real image dimension data.
 *
 * Pattern (12-item cycle):
 *   portrait · landscape · portrait · wide · square · portrait ·
 *   landscape · portrait · square · portrait · wide · landscape
 *
 * portrait  → 2 rows tall, 1 col  (tall card)
 * landscape → 1 row,  2 cols      (wide card)
 * wide      → 1 row,  3 cols      (very wide, like a panorama strip)
 * square    → 1 row,  1 col
 */
type Variant = 'portrait' | 'landscape' | 'square' | 'wide';

const PATTERN: Variant[] = [
  'portrait',  'landscape', 'portrait', 'wide',
  'square',    'portrait',  'landscape','portrait',
  'square',    'portrait',  'wide',     'landscape',
];

const photosWithVariant = photos.map((photo, i) => ({
  photo,
  variant: PATTERN[i % PATTERN.length],
}));
---

<section class="gallery-section" aria-label="Photo gallery">

  <!-- Filter bar -->
  <div class="filter-bar" role="group" aria-label="Filter by category">
    <button class="filter-btn" data-filter="all"
      aria-pressed={initialCategory === 'all' ? 'true' : 'false'}>
      All
    </button>
    {CATEGORIES.map(cat => (
      <button class="filter-btn" data-filter={cat.value}
        aria-pressed={initialCategory === cat.value ? 'true' : 'false'}>
        {cat.label}
      </button>
    ))}
  </div>

  <!-- Collage grid -->
  <div class="collage-grid" id="gallery-grid">
    {photosWithVariant.map(({ photo, variant }) => (
      <div
        class:list={['collage-cell', `collage-cell--${variant}`]}
        data-category={photo.category ?? 'other'}
      >
        <PhotoCard photo={photo} variant={variant} />
      </div>
    ))}
  </div>

  <!-- Empty state -->
  <p class="empty-state" id="gallery-empty" aria-live="polite" hidden>
    No photos in this category yet. Check back soon.
  </p>

</section>

<script>
  const grid    = document.getElementById('gallery-grid') as HTMLElement;
  const empty   = document.getElementById('gallery-empty') as HTMLElement;
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cells   = grid ? Array.from(grid.querySelectorAll<HTMLElement>('.collage-cell')) : [];

  const params = new URLSearchParams(window.location.search);
  let active  = params.get('category') ?? 'all';
  let pending: number | null = null;

  function applyFilter(filter: string) {
    active = filter;
    buttons.forEach(btn =>
      btn.setAttribute('aria-pressed', btn.dataset.filter === filter ? 'true' : 'false')
    );

    if (pending !== null) cancelAnimationFrame(pending);
    pending = requestAnimationFrame(() => {
      let visible = 0;
      cells.forEach(cell => {
        const match = filter === 'all' || cell.dataset.category === filter;
        cell.classList.toggle('cell-hidden', !match);
        if (match) visible++;
      });
      empty.hidden = visible > 0;
      pending = null;
    });

    const url = new URL(window.location.href);
    filter === 'all'
      ? url.searchParams.delete('category')
      : url.searchParams.set('category', filter);
    window.history.replaceState({}, '', url.toString());
  }

  applyFilter(active);
  buttons.forEach(btn =>
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all'))
  );
</script>

<style>
/* ── Section shell ── */
.gallery-section {
  padding: 8rem 2rem 5rem;
  max-width: 1400px;
  margin: 0 auto;
}

/* ── Filter bar ── */
.filter-bar {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}

.filter-btn {
  padding: 0.4rem 1rem;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: 1px solid rgba(245,240,232,0.16);
  border-radius: 999px;          /* pill shape */
  background: transparent;
  color: rgba(245,240,232,0.5);
  cursor: pointer;
  transition: border-color 0.18s, color 0.18s, background 0.18s;
}

.filter-btn:hover,
.filter-btn[aria-pressed="true"] {
  border-color: var(--sunset);
  color: var(--paper);
  background: rgba(200,90,42,0.12);
}

/* ── Collage grid ─────────────────────────────────────────────────────────── */
/*
  Auto-fill columns of 200px min, expanding to fill.
  Each base row is 180px. Variants span extra rows/cols.
*/
.collage-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  grid-auto-rows: 180px;
  gap: 10px;
}

/* ── Cell variants ── */
.collage-cell {
  min-width: 0;
  min-height: 0;
  transition: opacity 0.3s ease, transform 0.35s var(--ease-out-expo, cubic-bezier(0.16,1,0.3,1));
}

/* Portrait: tall — 2 rows, 1 col */
.collage-cell--portrait {
  grid-row: span 2;
}

/* Landscape: normal height, 2 cols wide */
.collage-cell--landscape {
  grid-column: span 2;
}

/* Wide: panorama strip — 1 row, 3 cols */
.collage-cell--wide {
  grid-column: span 3;
}

/* Square: 1×1 */
.collage-cell--square {
  /* default — no span */
}

/* ── Hidden (filtered out) ── */
.collage-cell.cell-hidden {
  opacity: 0;
  transform: scale(0.95);
  pointer-events: none;
  /* keep in flow to avoid grid reflow; just invisible */
  visibility: hidden;
}

/* ── Empty state ── */
.empty-state {
  text-align: center;
  padding: 4rem 0;
  color: rgba(245,240,232,0.3);
  font-size: 0.88rem;
  letter-spacing: 0.06em;
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .collage-grid {
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    grid-auto-rows: 160px;
    gap: 8px;
  }
  /* Collapse wide to 2 cols on tablet */
  .collage-cell--wide { grid-column: span 2; }
}

@media (max-width: 540px) {
  .gallery-section { padding: 7rem 1rem 4rem; }
  .collage-grid {
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 140px;
    gap: 6px;
  }
  /* On mobile: wide becomes 2-col, landscape stays 2-col, portrait stays 2-row */
  .collage-cell--wide     { grid-column: span 2; }
  .collage-cell--landscape{ grid-column: span 2; }
}
</style>
