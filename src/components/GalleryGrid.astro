---
import type { PhotoEntry, Category } from '../lib/photos';
import PhotoCard from './PhotoCard.astro';
import { CATEGORIES } from '../lib/categories';

interface Props {
  photos: PhotoEntry[];
  initialCategory?: Category | 'all';
}

const { photos, initialCategory = 'all' } = Astro.props;
---

<section class="gallery-section" aria-label="Photo gallery">
  <!-- Filter bar -->
  <div class="filter-bar" role="group" aria-label="Filter by category">
    <button class="filter-btn" data-filter="all" aria-pressed={initialCategory === 'all' ? 'true' : 'false'}>
      All
    </button>
    {CATEGORIES.map(cat => (
      <button
        class="filter-btn"
        data-filter={cat.value}
        aria-pressed={initialCategory === cat.value ? 'true' : 'false'}
      >
        {cat.label}
      </button>
    ))}
  </div>

  <!-- Grid -->
  <div class="gallery-grid" id="gallery-grid">
    {photos.map(photo => (
      <div class="card-wrap">
        <PhotoCard photo={photo} />
      </div>
    ))}
  </div>

  <!-- Empty state -->
  <p class="empty-state" id="gallery-empty" aria-live="polite" hidden>
    No photos in this category yet. Check back soon.
  </p>
</section>

<script>
  const grid    = document.getElementById('gallery-grid') as HTMLElement;
  const empty   = document.getElementById('gallery-empty') as HTMLElement;
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');

  // Use the wrapper divs so we animate the container, not the link element
  const wraps = grid ? Array.from(grid.querySelectorAll<HTMLElement>('.card-wrap')) : [];

  const params = new URLSearchParams(window.location.search);
  let active = params.get('category') ?? 'all';
  let pending: number | null = null;

  function applyFilter(filter: string) {
    active = filter;

    buttons.forEach(btn => {
      btn.setAttribute('aria-pressed', btn.dataset.filter === filter ? 'true' : 'false');
    });

    if (pending !== null) cancelAnimationFrame(pending);

    pending = requestAnimationFrame(() => {
      let visible = 0;
      wraps.forEach(wrap => {
        const card = wrap.querySelector<HTMLElement>('[data-category]');
        const match = filter === 'all' || card?.dataset.category === filter;
        if (match) {
          wrap.classList.remove('card-hidden');
          visible++;
        } else {
          wrap.classList.add('card-hidden');
        }
      });
      empty.hidden = visible > 0;
      pending = null;
    });

    const url = new URL(window.location.href);
    if (filter === 'all') url.searchParams.delete('category');
    else url.searchParams.set('category', filter);
    window.history.replaceState({}, '', url.toString());
  }

  applyFilter(active);

  buttons.forEach(btn => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all'));
  });
</script>

<style>
.gallery-section {
  padding: 8rem 2.5rem 5rem;
  max-width: 1280px;
  margin: 0 auto;
}

/* ── Filter bar ── */
.filter-bar {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.filter-btn {
  padding: 0.45rem 1.1rem;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: 1px solid rgba(245,240,232,0.18);
  border-radius: 2px;
  background: transparent;
  color: rgba(245,240,232,0.55);
  cursor: pointer;
  transition:
    border-color 0.18s ease,
    color 0.18s ease,
    background 0.18s ease;
}

.filter-btn:hover,
.filter-btn[aria-pressed="true"] {
  border-color: var(--sunset);
  color: var(--paper);
  background: rgba(200,90,42,0.1);
}

/* ── Grid ── */
.gallery-grid {
  columns: 3;
  column-gap: 1rem;
}

.card-wrap {
  break-inside: avoid;
  margin-bottom: 1rem;
  /* Smooth show/hide with opacity + scale instead of display:none reflow */
  transition:
    opacity 0.3s ease,
    transform 0.3s var(--ease-out-expo, cubic-bezier(0.16,1,0.3,1));
  will-change: opacity, transform;
}

.card-wrap.card-hidden {
  opacity: 0;
  transform: scale(0.97);
  pointer-events: none;
  position: absolute;
  visibility: hidden;
}

/* ── Empty state ── */
.empty-state {
  text-align: center;
  padding: 4rem 0;
  color: rgba(245,240,232,0.35);
  font-size: 0.9rem;
  letter-spacing: 0.05em;
}

@media (max-width: 900px) {
  .gallery-grid { columns: 2; }
}

@media (max-width: 540px) {
  .gallery-section { padding: 7rem 1.25rem 4rem; }
  .gallery-grid { columns: 1; }
}
</style>
