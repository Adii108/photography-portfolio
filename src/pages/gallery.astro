---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { SAMPLE_PHOTOS } from '../lib/samplePhotos';
import type { PhotoEntry } from '../lib/photos';
import photosData from '../data/photos.json';

// Use real photos from the data file if available, otherwise fall back to samples
const livePhotos = photosData as PhotoEntry[];
const photos = livePhotos.length > 0 ? livePhotos : SAMPLE_PHOTOS;
---

<BaseLayout
  title="Gallery — WildFrame"
  description="Browse nature, trekking, and travel photographs across mountains, forests, trails, sunsets and rivers."
>
  <div class="gallery-header">
    <p class="eyebrow">The Collection</p>
    <h1 class="display gallery-title">Gallery</h1>
  </div>

  <GalleryGrid photos={photos} />
</BaseLayout>

<!-- Hydrate with live data after page load -->
<script>
  import type { PhotoEntry } from '../lib/photos';

  const PATTERN = [
    'wide',      'portrait',  'portrait',
    'landscape', 'square',    'square',
    'portrait',  'landscape', 'square',
    'portrait',  'square',    'landscape',
    'wide',      'square',    'square',
    'square',    'portrait',  'landscape',
  ];

  async function loadLivePhotos() {
    try {
      const res = await fetch('/api/photos?limit=200');
      if (!res.ok) return;
      const data = await res.json() as { ok: boolean; photos: PhotoEntry[] };
      if (!data.ok || !data.photos?.length) return;

      const grid = document.getElementById('gallery-grid');
      if (!grid) return;

      // Build new card HTML from API response using the exact layout pattern and classes
      const html = data.photos.map((p, i) => {
        const alt = (p.caption ?? p.place ?? 'Nature photo').replace(/"/g, '&quot;');
        const cat = p.category ?? 'other';
        const variant = PATTERN[i % PATTERN.length];
        return `
          <div class="collage-cell collage-cell--${variant}" data-category="${cat}">
            <a href="/story/${p.slug}" class="photo-card photo-card--${variant}" aria-label="${alt}">
              <img src="${p.imageUrl}" alt="${alt}" loading="lazy" class="photo-card__img" />
              <div class="photo-card__info" aria-hidden="true">
                <span class="photo-card__cat">${cat}</span>
                ${p.place ? `<p class="photo-card__place">${p.place}</p>` : ''}
                ${p.caption ? `<p class="photo-card__caption">${p.caption}</p>` : ''}
              </div>
            </a>
          </div>`;
      }).join('');

      grid.innerHTML = html;

      // Re-apply current filter using the same transition classes as GalleryGrid
      const params = new URLSearchParams(window.location.search);
      const active = params.get('category') ?? 'all';
      const cells = Array.from(grid.querySelectorAll<HTMLElement>('.collage-cell'));
      const emptyEl = document.getElementById('gallery-empty');
      let visible = 0;
      cells.forEach(cell => {
        const match = active === 'all' || cell.dataset.category === active;
        cell.classList.toggle('cell-hidden', !match);
        if (match) visible++;
      });
      if (emptyEl) emptyEl.hidden = visible > 0;
    } catch {
      // API unavailable — keep sample photos
    }
  }

  loadLivePhotos();
</script>

<style>
.gallery-header {
  padding: 9rem 2.5rem 1rem;
  max-width: 1280px;
  margin: 0 auto;
}

.eyebrow {
  font-size: 0.68rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--sunset);
  margin-bottom: 0.5rem;
}

.gallery-title {
  font-size: clamp(3rem, 7vw, 6rem);
  color: var(--paper);
}

@media (max-width: 600px) {
  .gallery-header { padding: 8rem 1.25rem 0.5rem; }
}
</style>
