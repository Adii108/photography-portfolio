---
import Nav from '../components/Nav.astro';
import TextureLayer from '../components/TextureLayer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'WildFrame — Nature Travel Photography',
  description = 'A cinematic nature photography journal. Mountains, forests, trails, sunsets, rivers.',
  image = '/og-default.jpg',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="grain min-h-screen" style="background-color: var(--ink);">
    <TextureLayer />
    <Nav />
    <main class="relative z-10">
      <slot />
    </main>
    <footer class="relative z-10 footer">
      <p class="footer__text">
        &copy; {new Date().getFullYear()} WildFrame &mdash; Every frame, a world.
      </p>
    </footer>
  </body>
</html>

<style>
.footer {
  text-align: center;
  padding: 2.5rem 1rem;
  border-top: 1px solid rgba(245,240,232,0.06);
}
.footer__text {
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(245,240,232,0.3);
}
</style>
